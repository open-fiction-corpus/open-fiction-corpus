{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://open-fiction-corpus.example/schema/pack.schema.json",
  "title": "Open Fiction Corpus pack definition",
  "type": "object",
  "additionalProperties": false,
  "required": ["name", "description", "version", "filters"],
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "description": {"type": "string", "minLength": 1},
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "filters": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "language": {"type": "string", "pattern": "^[a-z]{2,3}(?:-[A-Z]{2})?$"},
        "forms": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string"}
        },
        "genres_any": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string"}
        },
        "quality_status": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string"}
        },
        "origin": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string"}
        }
      }
    },
    "exclude_flags": {
      "type": "array",
      "uniqueItems": true,
      "items": {"type": "string"}
    },
    "selection": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "max_works_per_author": {"type": "integer", "minimum": 1}
      }
    }
  }
}
